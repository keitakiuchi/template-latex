{
    "editor.formatOnSave": true,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/.cache": true,
        "**/.conda": true,
        "**/__pycache__": true,
        "**/workbench/tmp": true
    },
    "search.exclude": {
        "**/.cache": true,
        "**/.conda": true,
        "**/__pycache__": true,
        "**/workbench/tmp": true
    },
    "files.watcherExclude": {
        "**/.cache/**": true,
        "**/.conda/**": true,
        "**/__pycache__/**": true,
        "**/workbench/tmp/**": true
    },
    "[yaml]": {
        "editor.wordWrap": "on"
    },
    "terminal.integrated.allowChords": true,
    "terminal.integrated.autoApproveCommands": [
        "cd",
        "ls",
        "pwd",
        "find",
        "git status",
        "git diff"
    ],
    "cursor.terminal.autoApproveCommands": [
        "cd",
        "ls",
        "pwd",
        "find",
        "git status",
        "git diff"
    ]
}
