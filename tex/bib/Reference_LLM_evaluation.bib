@article{ferrarisArchitectureLanguageUnderstanding2025,
  title      = {The Architecture of Language: {{Understanding}} the Mechanics behind {{LLMs}}},
  shorttitle = {The Architecture of Language},
  author     = {Ferraris, Andrea Filippo and Audrito, Davide and Caro, Luigi Di and Poncib{\`o}, Cristina},
  year       = {2025},
