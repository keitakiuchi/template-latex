{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Read(./.env.*)",
      "Edit(./.env.*)",
      "Write(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./secrets/**)",
      "Write(./secrets/**)",
      "Read(./config/credentials.json)",
      "Edit(./config/credentials.json)",
      "Write(./config/credentials.json)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git tag *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/bash-firewall.sh"
          }
        ]
      }
    ]
  }
}
